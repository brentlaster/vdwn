{
  "manifest_version": 3,
  "name": "VidTool - Video Downloader",
  "version": "1.0.0",
  "description": "Download videos from any website via a local yt-dlp backend",
  "minimum_chrome_version": "88",
  "permissions": [
    "activeTab",
    "webRequest"
  ],
  "host_permissions": [
    "http://localhost:9160/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/detector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
